{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@develit-io/general-codes",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "unbuild",
        "cwd": "packages/general-codes"
      }
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "executor": "@nx/js:release-publish",
      "options": {
        "packageRoot": "packages/general-codes"
      }
    }
  }
}
