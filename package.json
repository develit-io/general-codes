{
  "name": "general-codes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "postinstall": "lefthook install",
    "reset": "find . -type d -name 'node_modules' -exec rm -rf {} +",
    "deps:graph": "nx graph",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "build:codes": "nx build @develit-io/general-codes",
    "release:codes": "nx release --projects=@develit-io/general-codes --skip-publish && git push --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@nx/js": "^22.5.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.11",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "lefthook": "^2.1.1",
    "lint-staged": "^16.2.7",
    "nx": "^22.5.1",
    "typescript": "^5.7.3",
    "unbuild": "^3.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "~4.1.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "git-hooks": {
    "pre-commit": "bunx lint-staged",
    "commit-msg": "bun commitlint --edit $1"
  },
  "lint-staged": {
    "*": [
      "biome check --fix ."
    ]
  }
}
